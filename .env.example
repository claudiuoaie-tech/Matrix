# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rotamatrix?schema=public"

# Server
PORT=3000

# CORS allowlist — comma-separated list of browser origins permitted to call the
# API (e.g. "https://matrix-web-di5w.onrender.com"). Leave blank in local dev to
# allow all origins; set it in production to lock the API to your frontend.
CORS_ORIGIN=""

# Twilio credentials
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
# The Twilio phone number (E.164) shifts are broadcast from
TWILIO_FROM_NUMBER="+15555555555"
# WhatsApp sender for outbound WhatsApp broadcasts (E.164, with or without the
# "whatsapp:" prefix). Twilio sandbox is +14155238886. Falls back to
# TWILIO_FROM_NUMBER if unset.
# NOTE: WhatsApp now routes through Whapi.cloud (below), NOT Twilio. These
# legacy Twilio WhatsApp vars are unused unless you re-enable the Twilio path.
TWILIO_WHATSAPP_FROM="+14155238886"

# Whapi.cloud — WhatsApp gateway (outbound + inbound). Bypasses Meta's 24h
# window so we can message cold recruits. SMS stays on Twilio above.
WHAPI_API_TOKEN=""
# The connected WhatsApp sender MSISDN (informational; Whapi infers it from token)
WHAPI_SENDER_ID="447366185883"
# Optional: gateway base URL override (default https://gate.whapi.cloud)
# WHAPI_BASE_URL="https://gate.whapi.cloud"
# Optional: shared secret for the inbound webhook; if set, Whapi must include it
# as ?token=... or an X-Whapi-Token header (configure it in the Whapi dashboard).
WHAPI_WEBHOOK_SECRET=""

# Public base URL Twilio uses to reach this server (used for signature validation).
# Must match the webhook URL configured in the Twilio console, e.g. https://api.example.com
PUBLIC_BASE_URL="http://localhost:3000"

# Set to "false" to bypass Twilio signature validation in local/dev testing
VALIDATE_TWILIO_SIGNATURE="true"

# Shared secret guarding all /api/admin/* routes. Required — admin routes return
# 503 until this is set. Use a long random value in production.
ADMIN_API_KEY="change-me-to-a-long-random-secret"

# Shared secret for the external integration gateway (/api/v1/external/*). External
# platforms (Zapier, Make, n8n, AI agents) send it as the `X-API-Key` header.
# Required — external routes return 503 until set. Use a long random value.
EXTERNAL_API_KEY="change-me-to-a-long-random-external-secret"

# Optional outbound webhook destination. Critical system events (NO_SHOW logged,
# RTW expiry, new holiday requests) POST a JSON payload here so external HR/sheets
# can sync in real time. Leave blank to disable (events log in mock mode instead).
OUTBOUND_WEBHOOK_URL=""
