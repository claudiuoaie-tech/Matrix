# Frontend (Next.js) environment.
#
# Base URL of the Matrix API backend. Because it is a NEXT_PUBLIC_* variable it
# is inlined at BUILD time, so it must be set before `next build` (on Render:
# set it on the matrix-web service before the first deploy). No trailing slash.
#
#   Local dev : http://localhost:3000
#   Render    : https://matrix-qxs1.onrender.com
NEXT_PUBLIC_API_URL="http://localhost:3000"
